<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Portfolio</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Calligraffitti&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.2.1/jquery.min.js">
    
    <link rel="stylesheet" href="/index.css">
    <link rel="stylesheet" href="/contact.css">
    <style>
        .input-box input, #btn-send {
            transition: transform 1s ease-in-out;
            position: relative; /* Ensure correct positioning */
        }

        .move-out {
            transform: translateX(-150%);
        }
    </style>
</head>
<body>
    <div class="grid-container">
        <header class="header">
            <%- include("header.ejs") %>
        </header>
        <main class="contact">
            <div class="wrapper">
                <form action="" id="contact-form">
                    <h2>Contact Me</h2>
                    <div class="input-box">
                        <input type="text" id="input-name" placeholder="Name" required>
                        <input type="email" id="input-email" placeholder="Email" required>
                        <input type="text" id="input-message" placeholder="Message" required>
                    </div>
                    <button id="btn-send" type="button" class="btn">Send</button>
                </form>
                
            </div>
            <div class="wrap"> 
                <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52"> <circle class="checkmark__circle" cx="26" cy="26" r="50" fill="none"/> <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/></svg>
            </div>
            
            
        </main>
  
        
    </div>
    <script>
        document.getElementById("btn-send").addEventListener("click", function() {
    var form = document.getElementById("contact-form");

    if (form.checkValidity()) {
        // Trigger the transition
        document.getElementById("input-name").classList.add('move-out');
        document.getElementById("input-email").classList.add('move-in');
        document.getElementById("input-message").classList.add('move-out');
        document.getElementById("btn-send").classList.add('move-in');

        document.querySelector('h2').style.visibility = 'hidden';

        setTimeout(function() {
            // Show the checkmark after inputs have moved out
            const wrap = document.querySelector('.wrap');
            wrap.style.display = 'flex';
            wrap.style.visibility = 'visible';

            // Trigger the animation
            document.querySelector('h2').innerText = 'Success!!';
            document.querySelector('h2').style.visibility = 'visible';
            
            document.querySelector('.checkmark__circle').style.animation = 'stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards';
            document.querySelector('.checkmark').style.animation = 'fill 0.4s ease-in-out 0.4s forwards, scale 0.3s ease-in-out 0.9s both';
            document.querySelector('.checkmark__check').style.animation = 'stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards';
        }, 900); // Adjust timing as needed

        setTimeout(function() {
            form.submit();
        }, 5000);
    } else {
        form.reportValidity();
    }
});

    </script>
</body>
</html>
